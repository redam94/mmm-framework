#!/bin/sh
# Pre-commit hook: run the same ruff gate as CI (.github/workflows/ci.yml).
# Install once per clone with `make hooks` (sets core.hooksPath to .githooks).
# Bypass in an emergency with `git commit --no-verify`.

repo_root=$(git rev-parse --show-toplevel) || exit 1
cd "$repo_root" || exit 1

if command -v uv >/dev/null 2>&1; then
    ruff_cmd="uv run ruff"
elif command -v ruff >/dev/null 2>&1; then
    ruff_cmd="ruff"
else
    echo "pre-commit: neither uv nor ruff found on PATH — skipping lint (CI will still enforce it)" >&2
    exit 0
fi

if ! $ruff_cmd check src api; then
    echo "" >&2
    echo "pre-commit: ruff check failed (this is what breaks CI)." >&2
    echo "  Auto-fix what it can:  $ruff_cmd check --fix src api" >&2
    echo "  Bypass this hook:      git commit --no-verify" >&2
    exit 1
fi
