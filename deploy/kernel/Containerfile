# PR-F.1 — the per-session kernel image (fit-capable).
#
# Build from the REPO ROOT:
#   REGISTRY_AUTH_FILE=<clean> podman build -t mmm-kernel:latest -f deploy/kernel/Containerfile .
#
# Design notes:
#  - Deps are PINNED (deploy/kernel/requirements.lock, generated by
#    `uv export --frozen --no-emit-project`) — supply-chain pinning per §4. Adding
#    --require-hashes is the prod hardening follow-up.
#  - The framework itself is pure Python, dropped on PYTHONPATH (the project has no
#    build backend; this avoids needing one and keeps the image source-transparent).
#  - Runs NON-ROOT (uid 10001). The provisioner adds the rest of the sandbox at run
#    time: --read-only rootfs + tmpfs for the writable dirs, --network none (ipc) or
#    an --internal net (tcp), cgroup mem/pids caps, seccomp, workspace-only mount,
#    masked /proc//sys (PR-F.2..F.5).
#  - tini is PID 1 so SIGINT/zombies behave when a compiled sampler ignores signals
#    (design §3.4).
FROM docker.io/library/python:3.12-slim

# pytensor/numba compile C/C++ at runtime; tini for correct PID-1 signal/zombie handling.
RUN apt-get update \
 && apt-get install -y --no-install-recommends g++ gcc tini \
 && rm -rf /var/lib/apt/lists/*

# Pinned dependency closure (no workspace package — that arrives via PYTHONPATH).
COPY deploy/kernel/requirements.lock /tmp/requirements.lock
RUN pip install --no-cache-dir -r /tmp/requirements.lock

# The framework source (pure Python) on PYTHONPATH.
COPY src/mmm_framework /opt/mmm/mmm_framework

# Non-root kernel user; writable scratch dirs default under /tmp (a tmpfs at run time).
RUN useradd --create-home --uid 10001 --shell /usr/sbin/nologin kernel
ENV PYTHONPATH=/opt/mmm \
    PYTHONDONTWRITEBYTECODE=1 \
    MPLBACKEND=Agg \
    MMM_AGENT_KERNEL=subprocess \
    PYTENSOR_FLAGS=base_compiledir=/tmp/pytensor \
    NUMBA_CACHE_DIR=/tmp/numba \
    MPLCONFIGDIR=/tmp/mpl \
    HOME=/home/kernel
USER kernel
WORKDIR /home/kernel

ENTRYPOINT ["tini", "--"]
CMD ["python", "-m", "ipykernel_launcher"]
