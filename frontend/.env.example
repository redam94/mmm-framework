# MMM Studio Frontend Configuration

# API Base URL.
#
# Leave this UNSET for normal development: the Vite dev server proxies /api/* to
# the backend (see vite.config.ts), so the app talks to a single origin and only
# the Vite port needs to be forwarded/tunneled.
#
# Set it ONLY to point at an absolute backend URL (e.g. a hosted API). Setting it
# disables the dev proxy routing, so do not set it if you rely on the tunnel.
# VITE_API_URL=http://localhost:8000

# Backend the dev-server proxy forwards /api/* to (default http://localhost:8000).
# Set this if your FastAPI backend runs on a different host/port.
# MMM_API_PROXY_TARGET=http://localhost:8000
